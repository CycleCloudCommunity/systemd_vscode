#!/usr/bin/env bash
<%

# Set our working directory.
working_dir = Pathname.new(context.working_dir)

# Ensure that code always starts up in either a user defined directory or the home directory.
if ! working_dir.exist?
    working_dir = Pathname.new(ENV['HOME'])
elsif working_dir.file?
    working_dir = working_dir.parent
end
%>

log() {
    echo "$(date '+%Y-%m-%dT%H:%M:%S%z'): $*"
}

if [[ ! -x "$HOME/code" ]]; then
    pushd "$HOME"

    vscode_cli_tarball="vscode_cli.tar.gz"
    vscode_cli_checksum_file="vscode_cli.sha256"
    vscode_cli_download_url='https://code.visualstudio.com/sha/download?build=stable&os=cli-alpine-x64'
    vscode_cli_checksum_url='https://code.visualstudio.com/sha?build=stable&os=cli-alpine-x64'

    log "Downloading VS Code CLI from ${vscode_cli_download_url}"
    if ! curl --fail --show-error --location --proto '=https' --tlsv1.2 "${vscode_cli_download_url}" --output "${vscode_cli_tarball}"; then
        log "ERROR: Failed to download VS Code CLI over TLS"
        popd
        exit 1
    fi

    log "Downloading VS Code CLI checksum from ${vscode_cli_checksum_url}"
    if ! curl --fail --show-error --location --proto '=https' --tlsv1.2 "${vscode_cli_checksum_url}" --output "${vscode_cli_checksum_file}"; then
        log "ERROR: Failed to download VS Code CLI checksum over TLS"
        rm -f "${vscode_cli_tarball}" "${vscode_cli_checksum_file}"
        popd
        exit 1
    fi

    # Parse SHA-256 checksum lines: 64 hexadecimal characters, optionally followed by whitespace and filename.
    vscode_cli_expected_checksum="$(awk 'match($0, /^[[:space:]]*([[:xdigit:]]{64})([[:space:]]+|$)/, m) { print m[1]; exit }' "${vscode_cli_checksum_file}")"
    if [[ -z "${vscode_cli_expected_checksum}" ]]; then
        log "ERROR: Could not parse VS Code CLI checksum"
        rm -f "${vscode_cli_tarball}" "${vscode_cli_checksum_file}"
        popd
        exit 1
    fi

    vscode_cli_actual_checksum="$(sha256sum "${vscode_cli_tarball}" | awk '{print $1}')"
    if [[ "${vscode_cli_actual_checksum}" != "${vscode_cli_expected_checksum}" ]]; then
        log "ERROR: VS Code CLI checksum verification failed"
        rm -f "${vscode_cli_tarball}" "${vscode_cli_checksum_file}"
        popd
        exit 1
    fi

    tar -xf "${vscode_cli_tarball}"
    rm -f "${vscode_cli_tarball}" "${vscode_cli_checksum_file}"
    popd
fi

# Print compute node.
log "Running on ${host}:$port"

#
# Start VSCode.
#
log "Start code serve-web"
echo ""

# Remove scheduler environment variables to make code server a login node
unset $(compgen -e SLURM_)
unset $(compgen -e PBS_)

$HOME/code serve-web \
    --accept-server-license-terms \
    --connection-token ${password} \
    --host 0.0.0.0 \
    --port $port \
    --log debug \
    --server-base-path rnode/${host}/$port/ 
